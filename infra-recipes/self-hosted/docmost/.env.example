# Docmost env
APP_URL=https://wiki.example.com
APP_SECRET=GENERATE_32_CHAR_RANDOM_HEX     # openssl rand -hex 32

# Postgres (point to shared-stack)
DATABASE_URL=postgresql://docmost:CHANGEME@app-postgres:5432/docmost

# Redis (DB 1 in shared-stack redis)
REDIS_URL=redis://:CHANGEME-REDIS-PASSWORD@app-redis:6379/1

# Storage
STORAGE_DRIVER=local
# For S3 / MinIO:
# STORAGE_DRIVER=s3
# AWS_S3_REGION=us-east-1
# AWS_S3_ENDPOINT=http://app-minio:9000
# AWS_S3_BUCKET=docmost
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Email (optional but recommended for invite + notifications)
MAIL_DRIVER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=postmaster@example.com
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=wiki@example.com
MAIL_FROM_NAME=Wiki
