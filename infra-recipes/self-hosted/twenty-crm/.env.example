# Twenty CRM env
TAG=latest
SERVER_URL=https://crm.example.com
APP_SECRET=GENERATE_32_CHAR_RANDOM       # openssl rand -hex 32

# Postgres (shared-stack)
PG_DATABASE_URL=postgresql://twenty:CHANGEME@app-postgres:5432/twenty

# Redis (DB 4 in shared-stack)
REDIS_URL=redis://:CHANGEME-REDIS-PASSWORD@app-redis:6379/4

# MinIO (shared)
STORAGE_TYPE=s3
STORAGE_S3_REGION=us-east-1
STORAGE_S3_NAME=twenty
STORAGE_S3_ENDPOINT=http://app-minio:9000
STORAGE_S3_ACCESS_KEY_ID=minioadmin
STORAGE_S3_SECRET_ACCESS_KEY=CHANGEME-MINIO-SECRET

# Email (optional)
EMAIL_DRIVER=smtp
EMAIL_FROM_ADDRESS=crm@example.com
EMAIL_FROM_NAME=Twenty CRM
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

TELEMETRY_ENABLED=false
IS_SIGN_UP_DISABLED=true                  # set false initially to create first user, then re-enable
